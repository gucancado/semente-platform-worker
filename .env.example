# semente-platform-worker — env vars
# Em produção: definir no Coolify (Settings → Environment Variables).

# Server
PORT=3000
LOG_LEVEL=info

# Postgres dedicado (semente-worker-postgres no Coolify)
DATABASE_URL=postgres://worker:CHANGEME@semente-worker-postgres:5432/worker

# Bloquim — para criar tarefas a partir do webhook
BLOQUIM_API_URL=https://bloquim.beeads.com.br/api/v1
# Bloquim usa um token por agente — definido em AGENT_TOKENS abaixo, formato:
# { "agent_name": { "worker_token": "X-Agent-Token aceitos", "bloquim_token": "para criar tarefas em nome desse agente", "fallback_workspace_id": "wks_sistema_xxx" } }
AGENT_TOKENS_JSON='{"atendente":{"worker_token":"CHANGEME","bloquim_token":"CHANGEME","fallback_workspace_id":"wks_sistema_xxx"}}'

# Evolution — para validar webhooks vindos do Evolution
EVOLUTION_WEBHOOK_SECRET=CHANGEME
